generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum Role {
  STUDENT
  ADMIN
}

enum CategoryType {
  MARKETPLACE
  SERVICE
  BOTH
}

enum Condition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
}

enum ListingStatus {
  ACTIVE
  SOLD
  REMOVED
}

enum ServiceStatus {
  ACTIVE
  PAUSED
  REMOVED
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELLED
}

enum MessageType {
  TEXT
  IMAGE
}

enum NotificationType {
  BOOKING_REQUEST
  BOOKING_ACCEPTED
  BOOKING_REJECTED
  NEW_MESSAGE
  NEW_REVIEW
  LISTING_INTEREST
}

enum ReportTargetType {
  USER
  LISTING
  SERVICE
  MESSAGE
}

enum ReportReason {
  SPAM
  INAPPROPRIATE
  FRAUD
  HARASSMENT
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWED
  DISMISSED
  ESCALATED
}

model User {
  id                   Int      @id @default(autoincrement())
  email                String   @unique
  password             String
  role                 Role     @default(STUDENT)
  collegeEmailVerified Boolean  @default(false)
  trustScore           Float    @default(0)
  averageRating        Float    @default(0)
  verifiedBadge        Boolean  @default(false)
  createdAt            DateTime @default(now())

  profile Profile?

  listings Listing[]
  services Service[]

  requestedBookings Booking[] @relation("RequesterBookings")
  providedBookings  Booking[] @relation("ProviderBookings")

  chatsA   Chat[]    @relation("ChatParticipantA")
  chatsB   Chat[]    @relation("ChatParticipantB")
  messages Message[]

  writtenReviews  Review[] @relation("ReviewerReviews")
  receivedReviews Review[] @relation("RevieweeReviews")

  notifications Notification[]
  reportsFiled  Report[]       @relation("ReporterReports")
  favorites     Favorite[]
  adminActions  AdminAction[]  @relation("AdminUserActions")

  @@map("users")
}

model Profile {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  name       String
  department String
  year       Int
  bio        String?
  skills     String[]
  interests  String[]
  photoUrl   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Category {
  id   Int          @id @default(autoincrement())
  name String       @unique
  type CategoryType
  icon String?

  listings Listing[]
  services Service[]

  @@map("categories")
}

model Listing {
  id            Int           @id @default(autoincrement())
  sellerId      Int
  categoryId    Int
  title         String        @db.VarChar(100)
  description   String        @db.VarChar(2000)
  price         Decimal       @db.Decimal(10, 2)
  condition     Condition
  status        ListingStatus @default(ACTIVE)
  interestCount Int           @default(0)
  createdAt     DateTime      @default(now())

  seller   User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  images    ListingImage[]
  chats     Chat[]
  favorites Favorite[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([status])
  @@map("listings")
}

model ListingImage {
  id        Int    @id @default(autoincrement())
  listingId Int
  url       String
  order     Int    @default(0)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_images")
}

model Service {
  id           Int           @id @default(autoincrement())
  providerId   Int
  categoryId   Int
  title        String        @db.VarChar(100)
  description  String        @db.VarChar(2000)
  isPaid       Boolean       @default(false)
  price        Decimal?      @db.Decimal(10, 2)
  status       ServiceStatus @default(ACTIVE)
  bookingCount Int           @default(0)
  createdAt    DateTime      @default(now())

  provider User     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  slots     AvailabilitySlot[]
  bookings  Booking[]
  chats     Chat[]
  favorites Favorite[]

  @@index([providerId])
  @@index([categoryId])
  @@index([status])
  @@map("services")
}

model AvailabilitySlot {
  id        Int      @id @default(autoincrement())
  serviceId Int
  date      DateTime
  startTime String
  endTime   String
  isBooked  Boolean  @default(false)

  service  Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([serviceId])
  @@map("availability_slots")
}

model Booking {
  id          Int           @id @default(autoincrement())
  serviceId   Int
  slotId      Int?
  requesterId Int
  providerId  Int
  status      BookingStatus @default(PENDING)
  message     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  service   Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  slot      AvailabilitySlot? @relation(fields: [slotId], references: [id], onDelete: SetNull)
  requester User              @relation("RequesterBookings", fields: [requesterId], references: [id], onDelete: Cascade)
  provider  User              @relation("ProviderBookings", fields: [providerId], references: [id], onDelete: Cascade)

  review Review?

  @@index([serviceId])
  @@index([slotId])
  @@index([requesterId])
  @@index([providerId])
  @@index([status])
  @@map("bookings")
}

model Chat {
  id             Int      @id @default(autoincrement())
  participantAId Int
  participantBId Int
  listingId      Int?
  serviceId      Int?
  createdAt      DateTime @default(now())

  participantA User     @relation("ChatParticipantA", fields: [participantAId], references: [id], onDelete: Cascade)
  participantB User     @relation("ChatParticipantB", fields: [participantBId], references: [id], onDelete: Cascade)
  listing      Listing? @relation(fields: [listingId], references: [id], onDelete: Cascade)
  service      Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  messages Message[]

  @@index([participantAId])
  @@index([participantBId])
  @@index([listingId])
  @@index([serviceId])
  @@map("chats")
}

model Message {
  id        Int         @id @default(autoincrement())
  chatId    Int
  senderId  Int
  content   String?
  type      MessageType @default(TEXT)
  imageUrl  String?
  seen      Boolean     @default(false)
  createdAt DateTime    @default(now())

  chat   Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([senderId])
  @@map("messages")
}

model Review {
  id         Int      @id @default(autoincrement())
  bookingId  Int      @unique
  reviewerId Int
  revieweeId Int
  rating     Int
  feedback   String?
  createdAt  DateTime @default(now())

  booking  Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewer User    @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee User    @relation("RevieweeReviews", fields: [revieweeId], references: [id], onDelete: Cascade)

  @@index([reviewerId])
  @@index([revieweeId])
  @@map("reviews")
}

model Notification {
  id          Int              @id @default(autoincrement())
  userId      Int
  type        NotificationType
  title       String
  body        String
  isRead      Boolean          @default(false)
  referenceId Int?
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@map("notifications")
}

model Report {
  id          Int              @id @default(autoincrement())
  reporterId  Int
  targetType  ReportTargetType
  targetId    Int
  reason      ReportReason
  description String?
  status      ReportStatus     @default(OPEN)
  createdAt   DateTime         @default(now())

  reporter User @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([targetType, targetId])
  @@index([status])
  @@map("reports")
}

model Favorite {
  id        Int  @id @default(autoincrement())
  userId    Int
  listingId Int?
  serviceId Int?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing? @relation(fields: [listingId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([listingId])
  @@index([serviceId])
  @@map("favorites")
}

model AdminAction {
  id         Int      @id @default(autoincrement())
  adminId    Int
  targetType String
  targetId   Int
  action     String
  createdAt  DateTime @default(now())

  admin User @relation("AdminUserActions", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([targetType, targetId])
  @@map("admin_actions")
}
